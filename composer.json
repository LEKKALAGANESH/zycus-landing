{
    "name": "zycus/landing",
    "description": "Zycus enterprise landing page — vanilla PHP 8.2 with PHPMailer and dotenv.",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "phpmailer/phpmailer": "^6.9",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Zycus\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Zycus\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "post-autoload-dump": [],
        "test": "phpunit --testdox",
        "lint": "find . -type f -name '*.php' -not -path './vendor/*' -not -path './storage/*' -exec php -l {} \\;"
    }
}
