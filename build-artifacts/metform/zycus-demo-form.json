{
  "_comment": "Reference schema for the Zycus Demo Request form. MetForm free does NOT support JSON import — this file is a logical blueprint for the human builder and for future programmatic tooling. Field 'name' attributes here MUST match what you type into MetForm's widget 'Name' field.",
  "form": {
    "name": "Zycus Demo Request",
    "id": "zycus_demo",
    "style": {
      "type": "multi_step",
      "progress_indicator": {
        "enabled": true,
        "position": "top",
        "style": "step_numbered_with_labels"
      }
    },
    "steps": [
      {
        "index": 1,
        "name": "About You",
        "fields": [
          {
            "id": "email",
            "type": "email",
            "label": "Work Email",
            "placeholder": "you@company.com",
            "required": true,
            "validation": {
              "format": "email",
              "custom": {
                "_comment": "Reject common free-email domains. In MetForm free, implement via custom regex or the functions.php snippet in the markdown appendix.",
                "rule": "reject_domains",
                "blocked_domains": [
                  "gmail.com",
                  "yahoo.com",
                  "hotmail.com",
                  "outlook.com"
                ],
                "error_message": "Please use your work email"
              }
            }
          },
          {
            "id": "first_name",
            "type": "text",
            "label": "First Name",
            "required": true
          },
          {
            "id": "last_name",
            "type": "text",
            "label": "Last Name",
            "required": true
          }
        ]
      },
      {
        "index": 2,
        "name": "About Your Company",
        "fields": [
          {
            "id": "company_name",
            "type": "text",
            "label": "Company Name",
            "required": true
          },
          {
            "id": "company_size",
            "type": "select",
            "label": "Company Size",
            "required": true,
            "_comment": "Values are stable IDs used by conditional redirect logic — do not rename without updating the redirects block below.",
            "options": [
              { "label": "1-49 employees", "value": "small" },
              { "label": "50-499 employees", "value": "mid" },
              { "label": "500-4,999 employees", "value": "enterprise" },
              { "label": "5,000+ employees", "value": "large_enterprise" }
            ]
          },
          {
            "id": "role",
            "type": "select",
            "label": "Your Role",
            "required": true,
            "options": [
              {
                "label": "Procurement Leader (CPO, VP, Director)",
                "value": "procurement_leader"
              },
              {
                "label": "Finance Leader (CFO, VP, Controller)",
                "value": "finance_leader"
              },
              { "label": "IT / Digital Transformation", "value": "it" },
              {
                "label": "Procurement Team Member",
                "value": "procurement_team"
              },
              { "label": "Other", "value": "other" }
            ]
          }
        ]
      },
      {
        "index": 3,
        "name": "Your Priority",
        "fields": [
          {
            "id": "use_case",
            "type": "select",
            "label": "Primary Use Case",
            "required": true,
            "options": [
              { "label": "Sourcing & Contract Management", "value": "s2c" },
              { "label": "Invoice Automation (AP)", "value": "ap" },
              { "label": "Supplier Management", "value": "supplier_mgmt" },
              { "label": "End-to-End Source-to-Pay", "value": "s2p" }
            ]
          },
          {
            "id": "notes",
            "type": "textarea",
            "label": "Anything else we should know?",
            "placeholder": "Tell us about your biggest procurement bottleneck",
            "required": false,
            "validation": {
              "max_length": 500
            }
          }
        ]
      }
    ],
    "submit": {
      "button_text": "Book My Demo",
      "microcopy": {
        "_comment": "Render as small muted text directly below the submit button.",
        "text": "We respect your inbox. No spam, no credit card required.",
        "style_hint": "font-size: 13px; color: #6b7280; text-align: center;"
      }
    },
    "redirects": {
      "_comment": "Rules evaluated top-down, first match wins. MetForm free supports only a single static redirect — multi-branch logic requires MetForm Pro OR the functions.php hook in the markdown guide.",
      "rules": [
        {
          "priority": 1,
          "name": "enterprise_route",
          "condition": {
            "operator": "OR",
            "clauses": [
              {
                "field": "company_size",
                "operator": "equals",
                "value": "enterprise"
              },
              {
                "field": "company_size",
                "operator": "equals",
                "value": "large_enterprise"
              }
            ]
          },
          "redirect_to": "https://calendly.com/zycus-enterprise-ae",
          "_comment": "Placeholder Calendly link — user must replace with real enterprise AE booking link before go-live."
        },
        {
          "priority": 2,
          "name": "self_serve_route",
          "condition": {
            "operator": "AND",
            "clauses": [
              {
                "field": "company_size",
                "operator": "equals",
                "value": "small"
              }
            ]
          },
          "redirect_to": "/self-serve-tour/"
        },
        {
          "priority": 3,
          "name": "default_fallback",
          "condition": { "operator": "DEFAULT" },
          "redirect_to": "/thank-you/?form=zycus_demo"
        }
      ]
    },
    "notifications": {
      "email": {
        "enabled": true,
        "to": "sales@zycus.landing.com",
        "from": "noreply@zycus.com",
        "_comment_from": "Replace zycus.com with the production sender domain (must have SPF + DKIM configured).",
        "reply_to": "[mf-form-data field=\"email\"]",
        "subject": "New Demo Request — [mf-form-data field=\"company_name\"]",
        "body_format": "html",
        "body": "<h2>New Zycus Demo Request</h2>\n<ul>\n  <li><strong>Work Email:</strong> [mf-form-data field=\"email\"]</li>\n  <li><strong>First Name:</strong> [mf-form-data field=\"first_name\"]</li>\n  <li><strong>Last Name:</strong> [mf-form-data field=\"last_name\"]</li>\n  <li><strong>Company Name:</strong> [mf-form-data field=\"company_name\"]</li>\n  <li><strong>Company Size:</strong> [mf-form-data field=\"company_size\"]</li>\n  <li><strong>Role:</strong> [mf-form-data field=\"role\"]</li>\n  <li><strong>Primary Use Case:</strong> [mf-form-data field=\"use_case\"]</li>\n  <li><strong>Notes:</strong> [mf-form-data field=\"notes\"]</li>\n</ul>\n<hr>\n<p><small>Submitted at: [mf-submission-date]<br>Source URL: [mf-page-url]</small></p>",
        "shortcode_reference": {
          "_comment": "These are MetForm's built-in shortcodes available in the Email Body editor.",
          "field_value": "[mf-form-data field=\"FIELD_NAME\"]",
          "submission_timestamp": "[mf-submission-date]",
          "page_url": "[mf-page-url]"
        }
      }
    },
    "embedding": {
      "_comment": "Form is inserted into a page via Elementor's MetForm widget — drag MetForm widget, choose 'Zycus Demo Request' in the Select Form dropdown.",
      "method": "elementor_widget",
      "widget_name": "MetForm",
      "form_selector_label": "Zycus Demo Request"
    }
  }
}
