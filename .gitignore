# ======================================================
# Secrets & environment
# ======================================================
.env
.env.*
!.env.example

# ======================================================
# Composer / PHP dependencies
# ======================================================
vendor/

# ======================================================
# Runtime storage (logs, sessions, cache)
# ======================================================
storage/logs/*
!storage/logs/.gitkeep
storage/cache/
storage/sessions/

# ======================================================
# Node (if added later for tooling)
# ======================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ======================================================
# Local build artefacts / backups
# ======================================================
*.log
*.bak
*.swp
*.swo
*~
*.orig

# ======================================================
# Editor / IDE
# ======================================================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.claude/

# ======================================================
# OS cruft
# ======================================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ======================================================
# Uploads / user-generated content
# ======================================================
public/uploads/
public/assets/downloads/*.pdf

# ======================================================
# Deployment artefacts
# ======================================================
deploy/
*.tar.gz
*.zip

# ======================================================
# Test / coverage
# ======================================================
/coverage/
/.phpunit.result.cache
.phpunit.cache/
