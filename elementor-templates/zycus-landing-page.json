    {
      "id": "testimonials_section",
      "elType": "section",
      "settings": {
        "background_background": "classic",
        "background_color": "#0f3d81",
        "background_image": {"url": ""},
        "custom_css_id": "testimonials",
        "padding": {"unit":"px","top":"80","right":"20","bottom":"80","left":"20","isLinked":false},
        "padding_tablet": {"unit":"px","top":"48","right":"20","bottom":"48","left":"20","isLinked":false}
      },
      "elements": [
        {
          "id": "test_col_head",
          "elType": "column",
          "settings": {"_column_size": 100},
          "elements": [
            {
              "id": "test_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Real Results from Real Procurement Leaders",
                "header_size": "h2",
                "align": "center",
                "typography_font_family": "Inter",
                "typography_font_weight": "700",
                "typography_font_size": {"unit":"px","size":36},
                "title_color": "#ffffff",
                "_animation": "fadeInUp"
              }
            },
            {
              "id": "test_sub",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"text-align:center;color:rgba(255,255,255,0.75);font-size:17px;max-width:720px;margin:0 auto 48px;\">Enterprises running Merlin AI in production — and the numbers they're hitting.</p>"
              }
            }
          ]
        },
        {
          "id": "test_col1",
          "elType": "column",
          "settings": {"_column_size": 50},
          "elements": [
            {
              "id": "testimonial1",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<article class=\"testimonial\" data-reveal=\"up\">\n  <div class=\"testimonial__quote-mark\" aria-hidden=\"true\">&ldquo;</div>\n  <blockquote class=\"testimonial__quote\">Zycus Merlin AI cut our invoice processing time by 75% in the first six months. What used to take a team of twelve now runs with four people and zero backlog. The AI doesn&rsquo;t just automate &mdash; it catches policy exceptions humans missed for years.</blockquote>\n  <footer class=\"testimonial__author\">\n    <div class=\"testimonial__avatar\" aria-hidden=\"true\">PV</div>\n    <div>\n      <div class=\"testimonial__name\">Priya Venkataraman</div>\n      <div class=\"testimonial__title\">Chief Procurement Officer, Global Consumer Goods Leader</div>\n    </div>\n  </footer>\n</article>"
              }
            }
          ]
        },
        {
          "id": "test_col2",
          "elType": "column",
          "settings": {"_column_size": 50},
          "elements": [
            {
              "id": "testimonial2",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<article class=\"testimonial\" data-reveal=\"up\" style=\"--d:150ms\">\n  <div class=\"testimonial__quote-mark\" aria-hidden=\"true\">&ldquo;</div>\n  <blockquote class=\"testimonial__quote\">We reduced supplier query response times by 80% and recovered $4.2M in duplicate and off-contract spend in year one. Zycus paid for itself before the rollout was even complete.</blockquote>\n  <footer class=\"testimonial__author\">\n    <div class=\"testimonial__avatar\" aria-hidden=\"true\">DO</div>\n    <div>\n      <div class=\"testimonial__name\">Daniel Osei</div>\n      <div class=\"testimonial__title\">Chief Financial Officer, Multinational Industrial Group</div>\n    </div>\n  </footer>\n</article>"
              }
            }
          ]
        }
      ]
    },
