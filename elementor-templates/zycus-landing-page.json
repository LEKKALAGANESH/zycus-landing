              "id": "faq_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Your Questions, Answered",
                "header_size": "h2",
                "align": "center",
                "typography_font_family": "Inter",
                "typography_font_weight": "700",
                "typography_font_size": {"unit":"px","size":36},
