            {
              "id": "hiw_heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "From Intake to Payment — Automated End-to-End",
                "header_size": "h2",
                "align": "center",
                "typography_font_family": "Inter",
                "typography_font_weight": "700",
                "typography_font_size": {"unit":"px","size":36},
                "typography_font_size_tablet": {"unit":"px","size":28},
                "title_color": "#0f3d81",
                "_animation": "fadeInUp"
