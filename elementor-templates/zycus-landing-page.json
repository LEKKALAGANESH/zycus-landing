            },
            {
              "id": "hiw_sub",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"text-align:center;color:#4a5b7a;font-size:17px;max-width:720px;margin:0 auto 48px;\">Merlin AI agents work alongside your team across every step of the Source-to-Pay lifecycle — eliminating manual handoffs, policy leakage, and approval bottlenecks.</p>"
              }
            }
          ]
        },
        {
          "id": "hiw_col1",
          "elType": "column",
          "settings": {"_column_size": 25},
          "elements": [
            {
              "id": "step1",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<div class=\"step-card\" data-reveal=\"up\"><div class=\"step-card__num\" aria-hidden=\"true\">1</div><h3 class=\"step-card__title\">Intake</h3><p class=\"step-card__desc\">Employees submit requests in natural language; Merlin routes them to the right buying channel automatically.</p></div>"
              }
            }
          ]
        },
        {
          "id": "hiw_col2",
          "elType": "column",
          "settings": {"_column_size": 25},
          "elements": [
            {
              "id": "step2",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<div class=\"step-card\" data-reveal=\"up\" style=\"--d:100ms\"><div class=\"step-card__num\" aria-hidden=\"true\">2</div><h3 class=\"step-card__title\">Sourcing</h3><p class=\"step-card__desc\">AI-drafted RFPs, auto-scored supplier responses, and guided negotiation shave weeks off every event.</p></div>"
              }
            }
          ]
        },
        {
          "id": "hiw_col3",
          "elType": "column",
          "settings": {"_column_size": 25},
          "elements": [
            {
              "id": "step3",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<div class=\"step-card\" data-reveal=\"up\" style=\"--d:200ms\"><div class=\"step-card__num\" aria-hidden=\"true\">3</div><h3 class=\"step-card__title\">Contracting</h3><p class=\"step-card__desc\">Redline clauses, track obligations, and surface risk instantly with a contract AI trained on your playbook.</p></div>"
              }
            }
          ]
        },
        {
          "id": "hiw_col4",
          "elType": "column",
          "settings": {"_column_size": 25},
          "elements": [
            {
              "id": "step4",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<div class=\"step-card\" data-reveal=\"up\" style=\"--d:300ms\"><div class=\"step-card__num\" aria-hidden=\"true\">4</div><h3 class=\"step-card__title\">Procure-to-Pay</h3><p class=\"step-card__desc\">Touchless POs, auto-matched invoices, and on-time payments keep suppliers happy and your books clean.</p></div>"
              }
            }
          ]
        }
      ]
