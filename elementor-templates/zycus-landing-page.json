              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<section class=\"logos\" aria-labelledby=\"logos-heading-el\" data-reveal=\"up\">\n  <div class=\"logos__viewport\" data-marquee>\n    <ul class=\"logos__row logos__track logos__track--fast\" role=\"list\" aria-hidden=\"true\">\n      <li class=\"logo-box\"><img src=\"/wp-content/themes/zycus-elementor/assets/img/logos/microsoft.jpg\" alt=\"\" loading=\"eager\" decoding=\"async\" width=\"140\" height=\"48\"></li>\n      <li class=\"logo-box\"><img src=\"/wp-content/themes/zycus-elementor/assets/img/logos/apple.jpg\" alt=\"\" loading=\"eager\" decoding=\"async\" width=\"140\" height=\"48\"></li>\n      <li class=\"logo-box\"><img src=\"/wp-content/themes/zycus-elementor/assets/img/logos/samsung.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"140\" height=\"48\"></li>\n      <li class=\"logo-box\"><img src=\"/wp-content/themes/zycus-elementor/assets/img/logos/meta.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"140\" height=\"48\"></li>\n      <li class=\"logo-box\"><img src=\"/wp-content/themes/zycus-elementor/assets/img/logos/netflix.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"140\" height=\"48\"></li>\n      <li class=\"logo-box\"><img src=\"/wp-content/themes/zycus-elementor/assets/img/logos/mercedes-benz.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"140\" height=\"48\"></li>\n      <li class=\"logo-box\"><img src=\"/wp-content/themes/zycus-elementor/assets/img/logos/bmw.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"140\" height=\"48\"></li>\n    </ul>\n  </div>\n  <div class=\"logos__viewport\" data-marquee style=\"margin-top:16px\">\n    <ul class=\"logos__row logos__track logos__track--reverse logos__track--slow\" role=\"list\" aria-hidden=\"true\">\n      <li class=\"logo-box\"><img src=\"/wp-content/themes/zycus-elementor/assets/img/logos/adidas.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"140\" height=\"48\"></li>\n      <li class=\"logo-box\"><img src=\"/wp-content/themes/zycus-elementor/assets/img/logos/nike.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"140\" height=\"48\"></li>\n      <li class=\"logo-box\"><img src=\"/wp-content/themes/zycus-elementor/assets/img/logos/cocacola.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"140\" height=\"48\"></li>\n      <li class=\"logo-box\"><img src=\"/wp-content/themes/zycus-elementor/assets/img/logos/starbucks.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"140\" height=\"48\"></li>\n      <li class=\"logo-box\"><img src=\"/wp-content/themes/zycus-elementor/assets/img/logos/youtube.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"140\" height=\"48\"></li>\n      <li class=\"logo-box\"><img src=\"/wp-content/themes/zycus-elementor/assets/img/logos/insta.jpg\" alt=\"\" loading=\"lazy\" decoding=\"async\" width=\"140\" height=\"48\"></li>\n    </ul>\n  </div>\n  <ul class=\"visually-hidden\" aria-label=\"Trusted by these enterprises\">\n    <li>Microsoft</li><li>Apple</li><li>Samsung</li><li>Meta</li><li>Netflix</li>\n    <li>Mercedes-Benz</li><li>BMW</li><li>Adidas</li><li>Nike</li>\n    <li>Coca-Cola</li><li>Starbucks</li><li>YouTube</li><li>Instagram</li>\n  </ul>\n</section>"
