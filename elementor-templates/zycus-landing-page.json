                "_animation": "fadeInUp"
              }
            },
            {
              "id": "faq_sub",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"text-align:center;color:#4a5b7a;font-size:17px;max-width:720px;margin:0 auto 48px;\">Everything procurement, finance, and IT leaders ask us before signing.</p>"
              }
            },
            {
              "id": "faq_accordion",
              "elType": "widget",
              "widgetType": "accordion",
              "settings": {
                "tabs": [
                  {
                    "_id": "faq1",
                    "tab_title": "Will Zycus integrate with our existing ERP (SAP, Oracle, NetSuite)?",
                    "tab_content": "Yes. Zycus ships with certified, pre-built connectors for SAP S/4HANA, SAP ECC, Oracle Fusion, Oracle EBS, NetSuite, Microsoft Dynamics, and Workday. Most integrations go live in under 4 weeks and sync invoices, POs, master data, and GL codes bi-directionally."
                  },
                  {
                    "_id": "faq2",
                    "tab_title": "How long does implementation actually take?",
                    "tab_content": "A typical mid-market rollout of Source-to-Contract goes live in 8–12 weeks. Full Source-to-Pay across multiple business units is usually 16–20 weeks. Our implementation team handles configuration, integration, and user enablement — your team focuses on process design."
                  },
                  {
                    "_id": "faq3",
                    "tab_title": "How is our procurement data kept secure?",
                    "tab_content": "Zycus is SOC 2 Type II, ISO 27001, and ISO 27701 certified. All data is encrypted in transit (TLS 1.3) and at rest (AES-256), hosted in your choice of AWS region with full data residency controls. We're GDPR, CCPA, and HIPAA compliant."
                  },
                  {
                    "_id": "faq4",
                    "tab_title": "What kind of ROI can we actually expect?",
                    "tab_content": "Customers typically report 40–60% reduction in cycle times, 5–8% savings on addressable spend, and 70%+ reduction in manual invoice handling within 12 months. We'll share a custom ROI model during your demo based on your current spend and team size."
                  }
                ],
                "selected_icon": {"value": "fas fa-plus", "library": "fa-solid"},
                "selected_active_icon": {"value": "fas fa-minus", "library": "fa-solid"},
                "title_html_tag": "div",
                "border_width": {"unit":"px","top":"1","right":"1","bottom":"1","left":"1","isLinked":true},
                "border_color": "#d6deeb",
                "tab_active_color": "#0f3d81",
                "title_background": "#ffffff",
                "title_color": "#0f3d81",
                "title_active_background": "rgba(64,164,251,0.04)",
                "content_color": "#0f3d81",
                "content_background_color": "#ffffff",
                "typography_font_family": "Inter",
                "typography_font_weight": "600",
                "typography_font_size": {"unit":"px","size":16},
                "content_typography_font_family": "Inter",
                "content_typography_font_size": {"unit":"px","size":15},
                "item_spacing": {"unit":"px","size":12}
