              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<div class=\"hero__visual\" data-reveal=\"scale\">\n  <div class=\"dashboard-mock\">\n    <div class=\"dashboard-mock__chrome\" aria-hidden=\"true\"><span></span><span></span><span></span></div>\n    <div class=\"dashboard-mock__body\">\n      <div class=\"dashboard-mock__sidebar\" aria-hidden=\"true\">\n        <div class=\"sk sk--lg\"></div>\n        <div class=\"sk\"></div><div class=\"sk\"></div><div class=\"sk\"></div><div class=\"sk\"></div>\n      </div>\n      <div class=\"dashboard-mock__main\">\n        <div class=\"dashboard-mock__title\">Merlin AI Dashboard</div>\n        <div class=\"dashboard-mock__stats\">\n          <div class=\"stat\"><div class=\"stat__label\">Spend Under Mgmt</div><div class=\"stat__value\" data-counter=\"4.2\" data-prefix=\"$\" data-suffix=\"B\" data-decimals=\"1\">$0.0B</div></div>\n          <div class=\"stat\"><div class=\"stat__label\">Cycle Time</div><div class=\"stat__value\" data-counter=\"-62\" data-suffix=\"%\">0%</div></div>\n          <div class=\"stat\"><div class=\"stat__label\">Auto-Approved</div><div class=\"stat__value\" data-counter=\"87\" data-suffix=\"%\">0%</div></div>\n        </div>\n        <div class=\"dashboard-mock__chart\">\n          <div class=\"bar\" style=\"--i:0;height:40%\"></div>\n          <div class=\"bar\" style=\"--i:1;height:62%\"></div>\n          <div class=\"bar\" style=\"--i:2;height:55%\"></div>\n          <div class=\"bar\" style=\"--i:3;height:78%\"></div>\n          <div class=\"bar\" style=\"--i:4;height:68%\"></div>\n          <div class=\"bar\" style=\"--i:5;height:90%\"></div>\n          <div class=\"bar\" style=\"--i:6;height:82%\"></div>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>"
              }
